{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/linkedin", "destination": "/linkedin-editor.html" },
    { "source": "/instagram", "destination": "/instagram-editor.html" },
    { "source": "/studio", "destination": "/product-studio.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
